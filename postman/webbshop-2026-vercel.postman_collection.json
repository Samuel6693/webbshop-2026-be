    {
      "name": "01 Auth",
      "item": [
        {
          "name": "POST /auth/register",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const email = `postman+${Date.now()}@example.com`;",
                  "pm.environment.set('currentUserEmail', email);",
                  "pm.environment.set('currentUserName', 'Postman Test User');",
                  "if (!pm.environment.get('userPassword')) {",
                  "  pm.environment.set('userPassword', 'Postman123!');",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "const data = pm.response.json();",
                  "pm.environment.set('userAccessToken', data.accessToken);",
                  "pm.environment.set('userRefreshToken', data.refreshToken);",
                  "pm.environment.set('userId', data.user.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"{{currentUserName}}\",\n  \"email\": \"{{currentUserEmail}}\",\n  \"password\": \"{{userPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            }
          },
          "response": []
        },
